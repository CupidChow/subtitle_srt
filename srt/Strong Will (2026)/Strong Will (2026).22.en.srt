732
00:46:53,520 --> 00:46:56,240
<font color="#ffffff">-Okay.</font><font color="#ffffff">
<font color="#ffffff">-One, two, three!<font color="#ffffff"></font></font></font>

733
00:46:56,320 --> 00:46:59,080
<font color="#ffffff">-We love you, Petch!</font><font color="#ffffff">
<font color="#ffffff">-We love you, Petch!<font color="#ffffff"></font></font></font>

734
00:47:00,760 --> 00:47:02,640
<font color="#ffffff">Wow!</font><font color="#ffffff"></font>

735
