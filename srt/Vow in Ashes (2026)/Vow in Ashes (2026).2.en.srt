207
00:12:18,760 --> 00:12:20,160
entered Room Tianzi Jia.

208
00:12:49,040 --> 00:12:49,600
Cui Mei.

209
00:12:49,880 --> 00:12:50,440
Cuimei.

210
00:12:51,480 --> 00:12:52,040
Yong.

211
00:12:53,120 --> 00:12:53,640
Huachao.

212
00:12:53,640 --> 00:12:54,570
Weikun Huachao.

213
00:12:56,360 --> 00:12:58,080
Longcong Biaohao.

214
00:13:01,800 --> 00:13:02,240
Shuang Bin.

215
00:13:02,200 --> 00:13:02,840
Ningzheng.

216
00:13:02,840 --> 00:13:03,500
Ningzheng.

217
00:13:05,400 --> 00:13:07,200
Haochun Kangshuaihua.

218
00:13:10,800 --> 00:13:11,720
Weichao.

219
00:13:13,080 --> 00:13:14,760
Qiangyuan Liangbo.

220
00:13:29,280 --> 00:13:29,640
Xi.

221
00:13:29,680 --> 00:13:30,040
Xi.

222
00:13:31,240 --> 00:13:31,840
Xi.

223
00:13:31,840 --> 00:13:33,160
Taoqiang.

224
00:13:36,760 --> 00:13:38,440
Huiyue Yunqing.

225
00:13:41,520 --> 00:13:42,640
Yiyi.

226
