ផ្នែកពិសេសបំផុតនៃវប្បធម៌របស់អ្នក។

886
00:39:33,640 --> 00:39:35,560
ខ្ញុំមិនគិតថាយើងអាចច្រៀងវាបានទេ។

887
00:39:35,560 --> 00:39:36,560
គ្រាន់តែមួយនោះ។

888
00:39:36,560 --> 00:39:38,080
បាទ ប្រភេទនោះ។

889
00:39:38,080 --> 00:39:39,360
បន្ទាប់មកយើងនឹងបង្រៀនចម្រៀង។

890
00:39:39,360 --> 00:39:41,240
ចម្រៀងប្រជាប្រិយពី Linzhi ។

891
00:39:41,240 --> 00:39:42,680
មើលថាតើអ្នកអាចរៀនវាបាន។

892
00:39:43,080 --> 00:39:43,520
មិនអីទេ។

893
00:39:55,560 --> 00:39:56,760
យើងរាំវាកាលនៅក្មេង។

894
00:39:57,640 --> 00:39:58,040
ពិតជា?

895
00:39:58,680 --> 00:39:59,320
តើជាបទដូចគ្នាទេ?

896
00:40:07,000 --> 00:40:08,320
Daxi អាចច្រៀងបាន Daxi ។

897
00:40:08,320 --> 00:40:09,080
ខ្ញុំអាចស្តាប់បាន។

898
00:40:09,800 --> 00:40:10,120
ស្តាប់ទៅល្អណាស់។

899
00:40:10,120 --> 00:40:10,680
គួរឱ្យចាប់អារម្មណ៍ណាស់។

900
00:40:10,680 --> 00:40:11,400
ស្តាប់ទៅល្អណាស់។

901
00:40:12,360 --> 00:40:13,760
អនុញ្ញាតឱ្យខ្ញុំស្វែងរកការបញ្ចេញសំឡេងត្រឹមត្រូវ។

902
00:40:15,200 --> 00:40:15,720
កុំស្តោះទឹកមាត់។

903
00:40:27,840 --> 00:40:29,400
លឺច្បាស់ជាងនាងទៅទៀត បងប្អូន

904
00:40:30,000 --> 00:40:31,120
អ្នក​អាច​ឮ​សំឡេង​នីមួយៗ​បាន​ច្បាស់។

905
00:40:38,440 --> 00:40:39,320
ពពែនៅទីនេះមែនទេ?

906
00:40:40,000 --> 00:40:40,760
ពពែនៅទីនេះ។

907
00:40:48,400 --> 00:40:49,400
នេះពិតជាមានរសជាតិ។

908
00:40:57,040 --> 00:40:57,440
មិនអីទេ។

909
00:40:57,440 --> 00:40:58,680
អ្នកពិតជាមានការចងចាំល្អ។

910
00:41:00,160 --> 00:41:00,920
ខ្ញុំ​ពូកែ​ខាង​នេះ។

911
00:41:01,520 --> 00:41:02,040
នៅទីនេះយើងទៅ។

912
00:41:02,440 --> 00:41:03,000
តោះមើលការសម្តែងរបស់អ្នក។

913
00:41:18,120 --> 00:41:19,040
នេះមិនដំណើរការទាំងស្រុងទេ។

914
00:41:19,040 --> 00:41:19,680
មិនបានឆ្លងកាត់។

915
00:41:21,320 --> 00:41:22,680
ទីមួយបានបរាជ័យ។

916
00:41:23,240 --> 00:41:24,680
អ្នកដែលមានទំនុកចិត្តបំផុតមិនឆ្លងកាត់ទេ។

917
00:41:35,560 --> 00:41:36,440
កាពូស៊ីណូ។

918
00:41:49,080 --> 00:41:50,360
សត្វព្រៃដូចជាខ្លាឃ្មុំពណ៌ត្នោត។

919
00:41:50,360 --> 00:41:51,920
ប្រហែល​ជា​ធ្លាក់​ចុះ​ពី​ភ្នំ​ទាំង​អស់។

920
00:41:51,920 --> 00:41:53,160
គោទើបតែមកដល់។

921
00:41:55,320 --> 00:41:56,520
មានអារម្មណ៍ថាវាកំពុងចាប់ផ្តើមភ្លៀង។

922
00:41:56,520 --> 00:41:57,880
បាទ វាមានអារម្មណ៍ដូចជាភ្លៀង។

923
00:41:58,480 --> 00:42:00,720
អាកាសធាតុប្រែប្រួលលឿនណាស់។

924
00:42:33,520 --> 00:42:34,920
តោះទៅញ៉ាំឥឡូវនេះ។

925
00:42:40,240 --> 00:42:40,760
ធ្វើបានល្អ។

926
00:42:40,760 --> 00:42:42,280
ស៊ុបជាមួយសាច់គោ។

927
00:42:43,120 --> 00:42:45,040
អាហារពេលល្ងាចនៅយប់នេះត្រូវបានរៀបចំសម្រាប់អ្នក។

928
00:42:45,040 --> 00:42:47,040
មាន់ជល់ថ្មហត្ថលេខារបស់ Linzhi ។

929
00:42:47,280 --> 00:42:48,520
ព្រលឹងនៃម្ហូបនេះ។

930
00:42:48,520 --> 00:42:51,320
លាក់ខ្លួនក្នុងចំណោមកំពូលភ្នំ Yarlung Zangbo Gorge ។

931
00:42:51,760 --> 00:42:54,440
សិប្បករ Monpa ឡើងភ្នំបីពាន់ម៉ែត្រ

932
00:42:54,440 --> 00:42:56,760
និងឆ្លាក់ថ្មសាប៊ូដ៏កម្រដោយដៃ

933
00:42:56,760 --> 00:42:57,720
ចូលទៅក្នុងរូបរាងនៃសក្តានុពលមួយ។

934
00:42:58,440 --> 00:42:59,440
ដុំថ្មទាំងមូល។

935
00:42:59,440 --> 00:43:00,040
ឆ្ងាញ់។

936
00:43:00,040 --> 00:43:01,520
ថ្ងៃនេះអ្នកត្រូវតែមានស៊ុបមួយចាន។

937
00:43:01,520 --> 00:43:01,880
មក។

938
00:43:08,360 --> 00:43:08,880
ហ៊ានណាស់។

939
00:43:11,880 --> 00:43:12,960
ស៊ុបបន្តិចធ្វើឱ្យអ្នកមានអារម្មណ៍ធូរស្រាល។

940
00:43:12,960 --> 00:43:13,840
អ្នកនឹងកក់ក្តៅភ្លាមៗ។

941
00:43:21,160 --> 00:43:22,920
នេះគឺជាសាច់គោល្អបំផុតដែលខ្ញុំមិនធ្លាប់មាន។

942
00:43:22,920 --> 00:43:23,560
នោះធ្វើឱ្យខ្ញុំភ្ញាក់ផ្អើល។

943
00:43:24,000 --> 00:43:25,520
ខ្ញុំមិនដែលស្រមៃទេ។

944
00:43:25,520 --> 00:43:26,600
សាច់យ៉ាកអាចមានរសជាតិឆ្ងាញ់នេះ។

945
00:43:27,880 --> 00:43:28,440
វាពិតជាទន់ភ្លន់ណាស់។

946
00:43:29,000 --> 00:43:30,840
ខ្ញុំ​គិត​ថា​វា​មក​ពី​សាច់​ខ្ចី។

947
00:43:30,840 --> 00:43:31,760
ផ្នែកខាងក្នុងនៃ tenderloin ។

948
00:43:31,760 --> 00:43:32,000
អាចជា។

949
00:43:32,000 --> 00:43:32,560
tenderloin តូច។

950
00:43:32,560 --> 00:43:34,920
នេះ​គ្រាន់​តែ​ជា​ការ​ល្អ​ដូច​ជា Chaozhou មួយ​។

951
00:43:37,120 --> 00:43:37,800
ប្រាំបីវិនាទី។

952
00:43:38,280 --> 00:43:38,600
ត្រូវហើយ។

953
00:43:39,040 --> 00:43:39,640
រាប់ដោយប្រុងប្រយ័ត្ន។

954
00:43:40,800 --> 00:43:41,760
ខ្ញុំសូមបន្ថែមសាច់ខ្លះទៅអ្នក។

955
00:43:42,120 --> 00:43:42,720
បន្ថែមសាច់ខ្លះ។

956
00:43:42,720 --> 00:43:43,280
ប្រាំបីវិនាទី។

957
00:43:43,280 --> 00:43:44,280
មួយ, ពីរ, បី, បួន, ប្រាំ, ប្រាំមួយ, ប្រាំពីរ

958
00:43:49,080 --> 00:43:49,760
ពីរ

959
00:43:49,760 --> 00:43:50,560
បី

960
00:43:50,840 --> 00:43:51,520
បួន

961
00:43:52,080 --> 00:43:52,720
ប្រាំ

962
00:43:53,440 --> 00:43:54,040
ប្រាំមួយ។

963
00:43:55,520 --> 00:43:56,800
ប្រាំពីរ

964
00:43:56,800 --> 00:43:58,360
បន្ទាប់ពីប្រាំបីវិនាទី សាច់នៅតែក្រហម។

965
00:43:58,360 --> 00:43:58,760
មិនអីទេ។

966
00:43:59,760 --> 00:44:00,640
យើងថែមទាំងញ៉ាំវាឆៅទៀតផង។

967
00:44:01,960 --> 00:44:02,560
ប្រាំបី

968
00:44:03,600 --> 00:44:04,480
ឱ្យវាពីរវិនាទីទៀត។

969
00:44:04,480 --> 00:44:05,200
ប្រាំបួន

970
00:44:06,320 --> 00:44:06,720
ដប់

971
00:44:07,240 --> 00:44:07,960
នេះពិតជាឆ្ងាញ់ណាស់។

972
00:44:09,560 --> 00:44:10,360
វា​មាន​រសជាតិ​ឆ្ងាញ់​សូម្បី​តែ​មិន​បាន​ជ្រលក់​។

973
00:44:10,360 --> 00:44:10,440
អាហារនេះពិតជាអស្ចារ្យណាស់។

974
00:44:10,440 --> 00:44:11,560
អាហារនេះពិតជាអស្ចារ្យណាស់។

975
00:44:11,560 --> 00:44:13,200
ប៉ុន្តែវានៅតែមានអារម្មណ៍ដូចជាបាត់អ្វីមួយ។

976
00:44:13,200 --> 00:44:14,280
បាត់​អ្វី?

977
00:44:14,280 --> 00:44:15,320
តើនេះមិនឆ្ងាញ់គ្រប់គ្រាន់ទេ?

978
00:44:15,320 --> 00:44:16,440
អ្នកគ្រាន់តែមិនទទួលបានវា។

979
00:44:16,840 --> 00:44:17,240
មក។

980
00:44:17,480 --> 00:44:18,680
អ្នកត្រូវការ Pepsi ជាមួយអាហារ។

981
00:44:18,680 --> 00:44:20,400
ញ៉ាំ Pepsi មួយខាំ។

982
00:44:20,400 --> 00:44:21,440
ដើម្បីអបអរសាទរយើង

983
00:44:21,440 --> 00:44:22,280
ជួបជុំគ្នាម្តងទៀត។

984
00:44:22,280 --> 00:44:22,760
តោះលើកកែវ។

985
00:44:25,120 --> 00:44:26,720
ស៊ីបនេះពិតជាពេញចិត្តណាស់។

986
00:44:27,080 --> 00:44:29,000
ញ៉ាំក៏ល្អ ផឹកក៏ល្អដែរ។

987
00:44:31,520 --> 00:44:32,920
តើយើងឈ្នះប្រអប់ផ្សិត Matsutake នេះទេ?

988
00:44:36,280 --> 00:44:37,440
យើងបានឈ្នះប្រអប់ផ្សិត Matsutake នោះ។

989
00:44:37,440 --> 00:44:38,440
ចុះ​តើ​គេ​ញ៉ាំ​វា​ដោយ​របៀប​ណា?

990
00:44:39,920 --> 00:44:41,200
ចេងចេង អត់ញ៉ាំអី?

991
00:44:41,840 --> 00:44:42,400
ខ្ញុំបានធ្វើហើយ បងប្រុស។

992
00:44:53,680 --> 00:44:54,840
បងប្រុស ថ្ងៃនេះខ្ញុំប្រើថាមពលច្រើនណាស់។

993
00:44:55,960 --> 00:44:57,440
ខ្ញុំពិតជាដុតខ្លាំងណាស់ថ្ងៃនេះ។

994
00:45:13,360 --> 00:45:15,160
គុយទាវ​នៅ​ទី​នោះ​ពិត​ជា​មាន​រស់​ជាតិ​ឆ្ងាញ់។

995
00:45:15,160 --> 00:45:15,880
ក្រអូបណាស់។

996
00:45:17,080 --> 00:45:17,880
ខ្ញុំជិតពេញហើយ។

997
00:45:17,880 --> 00:45:18,400
ខ្ញុំរួចរាល់ហើយ។

998
00:45:19,120 --> 00:45:19,880
មិនអាចញ៉ាំទៀតទេ។

999
00:45:22,040 --> 00:45:22,520
ភ្លៀងបានឈប់។

1000
00:45:22,880 --> 00:45:23,920
អ្នកគិតថាអ្នកល្អម្តងទៀត។

1001
00:45:25,840 --> 00:45:26,320
រកមើលនៅទីនោះ។

1002
00:45:28,080 --> 00:45:28,800
មួយនេះ។

1003
00:45:38,840 --> 00:45:40,080
ក្រពះរបស់ខ្ញុំកំពុងឡើង

1004
00:45:40,080 --> 00:45:41,080
ចន្លោះដែលសួតរបស់ខ្ញុំត្រូវការដកដង្ហើម។

1005
00:46:13,120 --> 00:46:14,440
កិច្ចការចុងក្រោយរបស់យើងថ្ងៃនេះ

1006
00:46:14,440 --> 00:46:16,200
គឺជាហ្គេមបុរាណមួយរបស់យើង។

1007
00:46:16,200 --> 00:46:17,320
រាំ Werewolf ។

1008
00:46:18,120 --> 00:46:19,320
នេះគឺនៅត្រង់ផ្លូវរបស់ខ្ញុំ។

1009
00:46:19,320 --> 00:46:20,040
មួយឆ្នាំមិនបានឃើញអ្នកទាំងអស់គ្នា។

1010
00:46:20,040 --> 00:46:21,600
តោះមកមើលជំនាញ Werewolf ទាំងអស់គ្នា

1011
00:46:21,600 --> 00:46:22,280
ឥឡូវនេះ។

1012
00:46:25,720 --> 00:46:27,080
នៅក្នុង Xizang មានប្រភេទមួយ។

1013
00:46:27,080 --> 00:46:28,600
នៃចចកជាមួយនឹងខ្សែឈាមតែមួយគត់។

1014
00:46:28,600 --> 00:46:29,760
វាត្រូវបានគេហៅថាឆ្កែចចកហិមាល័យ។

1015
00:46:30,720 --> 00:46:31,880
ដោយសារតែពួកគេកម្រណាស់,

1016
00:46:31,880 --> 00:46:33,920
ជាធម្មតាពួកគេបរបាញ់ជាក្រុមតូចៗ។

1017
00:46:33,920 --> 00:46:34,600
ពួកគេបរបាញ់ជាមួយគ្នា។

1018
00:46:35,200 --> 00:46:37,520
កូនឆ្កែចចកដើរតាមពីក្រោយកញ្ចប់ម៉ាញ់

1019
00:46:37,520 --> 00:46:39,400
ហើយរៀនពីគ្រប់ចលនារបស់ស្តេចចចក។

1020
00:46:39,400 --> 00:46:41,040
ដូច្នេះថ្ងៃនេះយើងនឹងលេង

1021
00:46:41,040 --> 00:46:42,720
កំណែកម្រិតខ្ពស់នៃ Dance Werewolf ។

1022
00:46:42,720 --> 00:46:43,520
មិនអីទេ។

1023
00:46:43,520 --> 00:46:44,760
គ្រប់គ្នាដោយមិនដឹងខ្លួន

1024
00:46:44,760 --> 00:46:46,280
អត្តសញ្ញាណរបស់គ្នាទៅវិញទៅមក,

1025
00:46:46,280 --> 00:46:48,680
នឹងរាំជាមួយតន្ត្រីនៅក្នុងកាសរបស់ពួកគេ។

1026
00:46:48,680 --> 00:46:50,520
ការងាររបស់ស្តេចចចកគឺស្វែងរកពីរ

1027
00:46:50,520 --> 00:46:51,800
កូនឆ្កែចចកដែលមិនចេះស្តាប់ភ្លេង

1028
00:46:51,800 --> 00:46:53,040
ហើយជួយពួកគេឱ្យលាក់ខ្លួន។

1029
00:46:53,040 --> 00:46:55,120
ប្រសិនបើក្រុមចៀមបោះឆ្នោតឱ្យស្តេចចចក

1030
00:46:55,120 --> 00:46:56,040
ពួកគេឈ្នះភ្លាមៗ។

1031
00:46:56,040 --> 00:46:58,760
ប្រសិនបើចចក និងចៀមមានចំនួនស្មើគ្នា។

1032
00:46:58,760 --> 00:46:59,800
ចចកឈ្នះ។

1033
00:47:00,280 --> 00:47:00,800
មិនអីទេ។

1034
00:47:02,160 --> 00:47:02,760
ឆ្កែចចក។

1035
00:47:02,760 --> 00:47:03,800
គ្មានតន្ត្រីនៅក្នុងត្រចៀករបស់ពួកគេ។

1036
00:47:04,040 --> 00:47:05,320
Wolf King មានតន្ត្រី។

1037
00:47:05,320 --> 00:47:07,040
ស្តេចចចកត្រូវតែស្វែងរកកូនឆ្កែចចក។

1038
00:47:07,040 --> 00:47:08,360
ហើយកុំចាប់។

1039
00:47:08,640 --> 00:47:09,440
ជុំសាកល្បង។

1040
00:47:10,080 --> 00:47:10,640
អ្នកណាចាញ់

1041
00:47:10,640 --> 00:47:11,800
ត្រលប់មកញ៉ាំមីកញ្ចប់នោះ។

1042
00:47:12,280 --> 00:47:13,240
ខ្ញុំមិនអាចញ៉ាំទៀតទេ។

1043
00:47:15,640 --> 00:47:15,960
មក។

1044
00:47:15,960 --> 00:47:16,520
តោះទៅ។

1045
00:47:22,680 --> 00:47:23,040
ដូចនេះ។

1046
00:47:23,040 --> 00:47:23,480
ប្រសិនបើ

1047
00:47:24,760 --> 00:47:25,640
ជុំសាកល្បងគឺល្អ

1048
00:47:25,640 --> 00:47:26,640
ប៉ុន្តែនៅក្នុងជុំផ្លូវការ

1049
00:47:26,640 --> 00:47:27,800
ប្រសិនបើក្នុងចំណោមសត្វចចកទាំងបី

1050
00:47:27,800 --> 00:47:29,920
តើខ្ញុំមិនអាចនៅជាមួយលោក Huang បានទេ?

1051
00:47:31,360 --> 00:47:31,800
ហេតុអ្វី?

1052
00:47:33,040 --> 00:47:34,480
គ្រាន់តែមានអារម្មណ៍ថាយើងប្រាកដជាចាញ់។

1053
00:47:41,920 --> 00:47:43,920
តួនាទីរបស់យើងត្រូវបានចាត់តាំងដោយចៃដន្យ។

1054
00:47:44,400 --> 00:47:45,160
យើង​គូរ​វា​លាយ​គ្នា​មែន​ទេ?

1055
00:47:45,160 --> 00:47:45,800
មិនអីទេ។

1056
00:47:47,520 --> 00:47:48,720
សូមបិទភ្នែកទាំងអស់គ្នា។

1057
00:47:51,080 --> 00:47:52,640
តួនាទីរបស់អ្នកជុំនេះគឺ Wolf King។

1058
00:47:55,280 --> 00:47:57,720
តួនាទីរបស់អ្នកជុំនេះគឺ Wolf Cub ។

1059
00:47:57,720 --> 00:47:59,160
គ្មានតន្ត្រី។

1060
00:47:59,160 --> 00:48:00,680
អ្នករាល់គ្នាបើកភ្នែករបស់អ្នក។

1061
00:48:08,160 --> 00:48:09,280
តើគាត់កំពុងដេកទេ?

1062
00:48:14,280 --> 00:48:15,040
តេង ភ្ញាក់ឡើង។

1063
00:48:19,000 --> 00:48:19,680
គេងមួយភ្លែត។

1064
00:48:20,280 --> 00:48:20,960
តេង ហាក់​មាន​ការ​សង្ស័យ។

1065
00:48:26,280 --> 00:48:27,720
តើខ្ញុំឮយ៉ាងម៉េច

1066
00:48:28,720 --> 00:48:30,880
តើអ្នកបានហាត់ហ្គេមនេះពេលសម្រាកទេ?

1067
00:48:33,840 --> 00:48:34,600
ហ្គេម Werewolf "ទទួលបាន" អ្នក។

1068
00:48:34,600 --> 00:48:35,520
គ្មានបញ្ហាធំទេ។

1069
00:48:35,520 --> 00:48:37,080
ខ្ញុំ​យល់​ពី​មនុស្ស​ឥឡូវ​នេះ។

1070
00:48:39,520 --> 00:48:40,280
តោះចាប់ផ្តើម។

1071
00:48:51,880 --> 00:48:52,720
គ្មាននរណាម្នាក់រាំទេ។

1072
00:48:59,640 --> 00:49:00,560
របស់អ្នកមិនមានសំឡេងទេ។

1073
00:49:10,320 --> 00:49:11,600
តើអ្នកទៅណា?

1074
00:49:11,600 --> 00:49:13,160
តើស្តេចចចកកំពុងបង្រៀនមែនទេ?

1075
00:49:13,160 --> 00:49:13,680
ទេ វាមិនមែនទេ។

1076
00:50:01,680 --> 00:50:02,560
តើអ្នករាំផ្នែកនេះដោយរបៀបណា?

1077
00:50:11,120 --> 00:50:12,000
តើអ្នករាំផ្នែកនេះដោយរបៀបណា?

1078
00:50:48,120 --> 00:50:49,040
អូខេ តន្ត្រីចប់ហើយ។

1079
00:50:51,840 --> 00:50:52,680
តេង​បាន​ដក​កាស​ចេញ។

1080
00:50:53,680 --> 00:50:54,320
ខ្ញុំអាច ខ្ញុំលឺ។

1081
00:50:54,640 --> 00:50:55,440
នៅតែមានតន្ត្រី។

1082
00:50:56,360 --> 00:50:58,320
តើអ្នកកំពុងព្យាយាមបញ្ឆោតខ្ញុំទេ?

1083
00:51:02,360 --> 00:51:03,320
ពេលឮបទនេះ

1084
00:51:03,320 --> 00:51:04,440
អ្នក​ថត​អ្វី​មួយ​មែន​ទេ?

1085
00:51:05,760 --> 00:51:07,680
ប្រសិនបើអ្នកដឹងអ្នកដឹង។

1086
00:51:07,680 --> 00:51:09,320
ដោយសារតែថ្មីៗនេះវាជាប្រភេទ

1087
00:51:09,640 --> 00:51:11,120
កំពុងពេញនិយមនៅលើវីដេអូខ្លីៗ។

1088
00:51:12,480 --> 00:51:14,120
ខ្ញុំពិតជាមិនមើលរឿងទាំងនោះទេ។

1089
00:51:15,040 --> 00:51:15,880
តើនោះគ្រាន់តែជាលេសទេ?

1090
00:51:20,200 --> 00:51:21,920
Fan Chengcheng បានរៀនវាបន្ទាប់ពីប្រាំនាទី។

1091
00:51:25,600 --> 00:51:26,280
ខ្ញុំបានរើសយកទាំងពីរនេះ។

1092
00:51:28,040 --> 00:51:28,440
WHO?

1093
00:51:28,800 --> 00:51:29,440
Chengcheng និង

1094
00:51:34,760 --> 00:51:35,560
Chengcheng និង

1095
00:51:35,560 --> 00:51:36,200
ថាតេង។

1096
00:51:43,080 --> 00:51:43,960
ខ្ញុំគិតថា Chengcheng មិនមែនទេ។

1097
00:51:43,960 --> 00:51:45,520
ដោយសារតែ Chengcheng គឺជាមនុស្សដំបូងដែលផ្លាស់ទី។

1098
00:51:47,080 --> 00:51:48,520
ខ្ញុំមិនគិតថាវាជា Chengcheng ទេ។

1099
00:51:49,520 --> 00:51:51,720
គ្រាន់​តែ​គាត់​រាំ​មុន​បន្តិច។

1100
00:51:51,720 --> 00:51:53,640
ប៉ុន្តែ​ផ្នែក​ដែល​គាត់​រាំ​មិន​មែន​ជា​ផ្នែក​នោះ​ទេ។

1101
00:51:53,640 --> 00:51:54,280
ទេ

1102
00:51:54,280 --> 00:51:55,920
គាត់បានរាំនៅពេលចាប់ផ្តើម។

1103
00:51:56,280 --> 00:51:58,200
ខ្ញុំ​បាន​តែ​រាំ​ផ្នែក​នោះ​ដើម្បី​ផ្លុំ។

1104
00:51:58,200 --> 00:51:59,160
តើអ្នកណានឹងគាំទ្រខ្ញុំ?

1105
00:51:59,160 --> 00:51:59,760
មិនបានរំពឹងទុកនោះទេ។

1106
00:52:01,640 --> 00:52:02,880
តើខ្ញុំបម្រុងទុកអ្នកដោយរបៀបណា?

1107
00:52:02,880 --> 00:52:03,640
បន្ទាប់ពីអ្នកទាត់ខ្ញុំ,

1108
00:52:03,640 --> 00:52:04,520
darn វាបន្ទាប់មកអ្នកបានធ្វើនេះ។

1109
00:52:04,520 --> 00:52:05,160
ខ្ញុំក៏មិនបានទទួលវាដែរ។

1110
00:52:05,720 --> 00:52:06,440
តើនេះជាអ្វី?

1111
00:52:06,800 --> 00:52:07,920
ពន្យល់ថានេះជាអ្វី។

1112
00:52:08,080 --> 00:52:09,160
អ្នកមើលទៅមានកំហុស។

1113
00:52:10,280 --> 00:52:12,480
ខ្ញុំ​ហ៊ាន​និយាយ​ថា​បទ​នេះ​ជា​ភាសា​អ្វី។

1114
00:52:15,640 --> 00:52:16,640
ខ្ញុំខ្លាចមនុស្សដឹង។

1115
00:52:17,880 --> 00:52:19,320
ជុំ​បន្ទាប់​បទ​ផ្លាស់​ប្តូ​រ​បង​ប្អូន។

1116
00:52:19,320 --> 00:52:20,400
និយាយថាវាជាភាសាអ្វី។

1117
00:52:24,040 --> 00:52:24,560
ប៉ុន្តែឥឡូវនេះ

1118
00:52:25,120 --> 00:52:26,240
ប៉ុន្តែ​ឥឡូវ​នេះ​យើង​មិន​អាច​នៅ​ឡើយ​ទេ​។

1119
00:52:26,240 --> 00:52:27,040
មិនទាន់អាចនិយាយបានទេ។

1120
00:52:31,680 --> 00:52:32,440
មិនអីទេ ទៅមុខ។

1121
00:52:33,360 --> 00:52:35,200
ហេតុអ្វីបានជាអ្នកភ័យ?

1122
00:52:35,200 --> 00:52:35,800
ខ្ញុំមិនភ័យទេ។

1123
00:52:36,240 --> 00:52:37,640
ប្រតិកម្មរបស់អ្នកពិតជាធ្វើឱ្យខ្ញុំ

1124
00:52:37,640 --> 00:52:38,360
អ្នកកំពុងធ្វើរឿងចម្លែក។

1125
00:52:39,640 --> 00:52:40,200
អនុញ្ញាតឱ្យខ្ញុំប្រាប់អ្នក,

1126
00:52:40,560 --> 00:52:42,800
យើងបានផ្គូផ្គងចង្វាក់នៃជុំទាំងនោះ។

1127
00:52:43,040 --> 00:52:44,120
ទីមួយ Bai

1128
00:52:44,120 --> 00:52:45,120
ខ្ញុំបានផ្គូផ្គងចង្វាក់ជាមួយអ្នក។

1129
00:52:45,120 --> 00:52:45,920
ខ្ញុំសុខសប្បាយទេមែនទេ?

1130
00:52:48,160 --> 00:52:49,080
អ្នក​មិន​ត្រូវ​គ្នា​ជាមួយ​នឹង​ខ្ញុំ​។

1131
00:52:49,080 --> 00:52:50,480
ខ្ញុំគ្រាន់តែធ្វើតាមការវាយដំរបស់ខ្ញុំប៉ុណ្ណោះ។

1132
00:52:50,480 --> 00:52:51,360
ហើយអ្នកគ្រាន់តែមើលខ្ញុំ។

1133
00:52:51,960 --> 00:52:52,920
ខ្ញុំមិនផ្គូផ្គងចង្វាក់ជាមួយអ្នកទេ។

1134
00:52:52,920 --> 00:52:53,600
ខ្ញុំធ្វើតាមការវាយដំរបស់ខ្ញុំ ហើយបន្ទាប់មកអ្នក។

1135
00:52:53,600 --> 00:52:54,680
Bing ខ្ញុំបានផ្គូផ្គងចង្វាក់ជាមួយអ្នកមែនទេ?

1136
00:52:57,720 --> 00:52:58,280
អាន់យូ ស្តេចចចក។

1137
00:53:03,280 --> 00:53:03,720
លោក Wang Anyu ។

1138
00:53:03,720 --> 00:53:05,160
អ្នក​ធ្វើ​ដូច​ជា​គ្រូ​ប្រឡង។

1139
00:53:06,280 --> 00:53:06,840
បាទ។

1140
00:53:07,080 --> 00:53:08,840
ប្រតិកម្មរបស់គាត់គឺច្បាស់ណាស់។

1141
00:53:08,840 --> 00:53:09,400
ធ្វើឱ្យមនុស្សត្រូវគ្នាជាមួយអ្នក។

1142
00:53:09,400 --> 00:53:10,200
វាដោយសារតែ

1143
00:53:10,200 --> 00:53:11,520
ហើយបន្ទាប់មកអ្នកមិនធ្វើអ្វីសោះ។

1144
00:53:11,520 --> 00:53:12,120
វា​ដោយ​សារ​តែ​ខ្ញុំ​មាន​ទំនុក​ចិត្ត។

1145
00:53:12,120 --> 00:53:13,040
អ្នកមិនធ្វើអ្វីសោះ។

1146
00:53:16,160 --> 00:53:16,720
ខ្ញុំ​បោះឆ្នោត​ឲ្យ​ណា​យូ។

1147
00:53:16,720 --> 00:53:17,240
ខ្ញុំ​បោះឆ្នោត​ឲ្យ​ណា​យូ។

1148
00:53:17,240 --> 00:53:17,840
ខ្ញុំក៏បោះឆ្នោតអោយ Anyu ដែរ។

1149
00:53:18,120 --> 00:53:18,680
ម៉ាក់។

1150
00:53:18,680 --> 00:53:19,040
បោះឆ្នោតឲ្យ អានី។

1151
00:53:19,440 --> 00:53:20,160
បោះឆ្នោតឲ្យ អានី។

1152
00:53:20,160 --> 00:53:20,600
បោះឆ្នោតឲ្យ អានី។

1153
00:53:20,600 --> 00:53:21,240
ខ្ញុំសូមប្រាប់អ្នកទាំងអស់គ្នា,

1154
00:53:21,560 --> 00:53:23,480
អ្នកទទួលបានតែពីរជុំដើម្បីជ្រើសរើស។

1155
00:53:23,480 --> 00:53:24,240
គ្រាន់​តែ​លេង​ក៏​មិន​អី​ដែរ។

1156
00:53:24,560 --> 00:53:24,920
បោះឆ្នោតឲ្យ អានី។

1157
00:53:27,480 --> 00:53:28,040
បោះឆ្នោតជាឯកច្ឆ័ន្ទ គាត់ចេញហើយ។

1158
00:53:29,120 --> 00:53:29,600
ស្តេចចចក។

1159
00:53:30,120 --> 00:53:30,560
ស្តេចចចក។

1160
00:53:30,840 --> 00:53:32,040
តួនាទីរបស់អាន់យូគឺ

1161
00:53:37,080 --> 00:53:37,600
ចៀមតូច។

1162
00:53:41,240 --> 00:53:42,360
ពិត។

1163
00:53:44,640 --> 00:53:45,200
បន្ទាប់មកអ្នក។

1164
00:53:45,200 --> 00:53:47,160
អ្នក​គឺ​ជា​ដំបង​ធំ​ណាស់​អ្នក​។

1165
00:53:49,320 --> 00:53:51,680
ខ្ញុំមិនដែលលេង Werewolf ក្នុងរដូវកាលនេះទៀតទេ។

1166
00:53:51,680 --> 00:53:52,200
មែនទេ?

1167
00:53:52,200 --> 00:53:52,800
នេះនឹងមិនធ្វើទេ។

1168
00:53:52,800 --> 00:53:54,160
ខ្ញុំ​មិន​ទាន់​បាន​បង្ហាញ​ខ្លួន​ឯង​នៅ​ឡើយ​ទេ។

1169
00:53:55,200 --> 00:53:56,520
អ្នក​បាន​បញ្ជាក់​ខ្លួន​ឯង។

1170
00:53:56,520 --> 00:53:58,200
អ្នកបានបង្ហាញខ្លួនឯងយ៉ាងល្អ។

1171
00:53:58,440 --> 00:54:00,080
តើខ្ញុំបញ្ជាក់ខ្លួនឯងដោយរបៀបណា?

1172
00:54:00,080 --> 00:54:02,440
ហ្គេមនេះមិនមែនសម្រាប់អ្នកទេ។

1173
00:54:05,280 --> 00:54:06,280
សម្រាប់ហ្គេមលាក់កំបាំង

1174
00:54:06,280 --> 00:54:08,040
យើងបានធ្វើសមយុទ្ធជាបន្តបន្ទាប់។

1175
00:54:10,240 --> 00:54:10,640
ខ្ញុំមិនមែនទេ។

1176
00:54:10,640 --> 00:54:12,280
ខ្ញុំបានចង្អុលបង្ហាញបញ្ហាធ្ងន់ធ្ងរ។

1177
00:54:12,720 --> 00:54:14,000
ឥឡូវនេះ Allen

1178
00:54:14,000 --> 00:54:15,280
ពេលពាក់កាស,

1179
00:54:15,440 --> 00:54:16,960
កំពុងស្តាប់យ៉ាងជិតស្និទ្ធជាមួយ Bing ។

1180
00:54:16,960 --> 00:54:17,160
បាទ។

1181
00:54:21,320 --> 00:54:22,680
អ្នកត្រូវពាក់ពួកវាដោយសម្លេង។

1182
00:54:22,680 --> 00:54:23,400
តើអ្នកអាចឮអ្វី?

1183
00:54:23,400 --> 00:54:23,800
ទៅស្តាប់។

1184
00:54:32,440 --> 00:54:33,840
តើអ្នកឆ្លើយតបយ៉ាងដូចម្តេច?

1185
00:54:34,040 --> 00:54:34,520
ការចាកចេញ។

1186
00:54:35,280 --> 00:54:36,040
គ្រាន់តែបោះជំហានទៅមុខ។

1187
00:54:38,520 --> 00:54:39,840
តួនាទីរបស់ Allen គឺ Wolf Cub ។

1188
00:54:45,520 --> 00:54:46,280
បេសកកម្មនៅតែបន្ត។

1189
00:54:46,280 --> 00:54:46,880
ហេតុអ្វីបានជាវានៅតែទៅ?

1190
00:54:46,880 --> 00:54:48,240
វាមិនទាន់ចប់ទេបន្ទាប់ពីពីរជុំ?

1191
00:54:48,600 --> 00:54:50,600
នៅពេលចចកនិងចៀម

1192
00:54:50,600 --> 00:54:52,000
មានចំនួនស្មើគ្នា,

1193
00:54:52,280 --> 00:54:53,480
ក្រុមចចកឈ្នះ។

1194
00:54:53,760 --> 00:54:55,600
ឥឡូវនេះលេខមិនស្មើគ្នាទេ។

1195
00:54:55,920 --> 00:54:57,120
បេសកកម្មត្រូវតែបន្ត។

1196
00:54:58,720 --> 00:54:59,480
មានមួយជុំទៀត។

1197
00:55:04,720 --> 00:55:05,920
តើ Chengcheng មានរឿងអ្វីចង់និយាយទេ?

1198
00:55:06,880 --> 00:55:07,600
វគ្គសាកល្បងបានបញ្ចប់។

1199
00:55:11,920 --> 00:55:13,240
Chengcheng គឺជាកូនឆ្កែចចក។

1200
00:55:13,240 --> 00:55:13,880
ស្តេចចចក

1201
00:55:14,240 --> 00:55:15,240
Bai Jingting

1202
00:55:16,600 --> 00:55:17,480
ពិតប្រាកដ។

1203
00:55:17,480 --> 00:55:19,600
ហេតុ​អ្វី​បាន​ជា​អ្នក​ព្យាយាម​ធ្វើ​ឱ្យ​រឿង​នេះ​ឡើង​?

1204
00:55:20,240 --> 00:55:22,480
បើអ្នកនៅស្ងៀម យើងឈ្នះ។

1205
00:55:22,480 --> 00:55:24,960
រង់ចាំ ខ្ញុំគិតថាយើងទាំងអស់គ្នាឈ្នះ។

1206
00:55:24,960 --> 00:55:26,600
ចុះ​ម៉េច​ក៏​ចេះ​រាំ​នោះ?

1207
00:55:27,240 --> 00:55:27,880
អ្នកក៏មិនមានតន្ត្រីដែរ។

1208
00:55:28,880 --> 00:55:30,000
ខ្ញុំចូលចិត្តមើលវីដេអូខ្លីៗ។

1209
00:55:32,400 --> 00:55:35,000
Chengcheng មិនមានភ្លេងនៅក្នុងជុំទីមួយទេ។

1210
00:55:35,320 --> 00:55:36,120
តើគាត់បានធ្វើអ្វី?

1211
00:55:36,120 --> 00:55:37,720
គាត់បានធ្វើរាល់ការរាំតាមអ៊ីនធឺណិត។

1212
00:55:37,720 --> 00:55:38,760
គាត់រាំទាំងអស់គ្នានៅទីនេះ។

1213
00:55:39,120 --> 00:55:40,520
ខ្ញុំគ្រាន់តែមើលគាត់នៅទីនោះ។

1214
00:55:48,280 --> 00:55:49,760
អត់​ទេ រឿង​គឺ​ខ្ញុំ​មិន​ដឹង​ការ​រាំ​របស់​អ្នក​ទេ។

1215
00:55:50,640 --> 00:55:51,640
ចម្រៀងថ្នាក់រាំរបស់ពួកគេ។

1216
00:55:51,640 --> 00:55:52,880
ដាស៊ី, រាំដំបូង។

1217
00:55:55,520 --> 00:55:56,960
អ្នកមិនដែលអានសៀវភៅទេ។

1218
00:55:57,320 --> 00:55:58,600
ធ្វើដំណើរមួយម៉ឺនគីឡូម៉ែត្រ។

1219
00:55:59,080 --> 00:56:00,400
អានសៀវភៅមួយម៉ឺនក្បាល។

1220
00:56:00,400 --> 00:56:01,520
ខ្ញុំមិនដែលឃើញវាតាមអ៊ីនធឺណិតទេ។

1221
00:56:02,000 --> 00:56:02,760
ខ្ញុំពិតជាមិនអាចធ្វើមួយនេះបានទេ។

1222
00:56:03,520 --> 00:56:04,280
ខ្ញុំពិតជាមិនអាចធ្វើមួយនេះបានទេ។

1223
00:56:07,240 --> 00:56:08,200
ខ្ញុំអាចធ្វើមួយនេះ។

1224
00:56:09,640 --> 00:56:10,400
ញ័រស្មា។

1225
00:56:11,240 --> 00:56:12,440
ខាងក្រៅ បន្ទាប់មកខាងក្នុង។

1226
00:56:21,640 --> 00:56:22,680
នេះគឺដូចជាការងូតទឹក។

1227
00:56:22,680 --> 00:56:23,680
មើលថាតើទឹកក្តៅឬអត់។

1228
00:56:26,520 --> 00:56:27,480
ក្តៅ។

1229
00:56:30,120 --> 00:56:32,280
ឥឡូវនេះមនុស្សគ្រប់គ្នាដឹងពីច្បាប់។

1230
00:56:32,280 --> 00:56:34,040
យើងចាប់ផ្តើមជាផ្លូវការហើយ។

1231
00:56:35,360 --> 00:56:36,640
សូមបិទភ្នែកទាំងអស់គ្នា។

1232
00:56:40,440 --> 00:56:42,400
តួនាទីរបស់អ្នកជុំនេះគឺ Wolf King។

1233
00:56:44,880 --> 00:56:47,280
តួនាទីរបស់អ្នកជុំនេះគឺកូនឆ្កែចចក។

1234
00:56:47,280 --> 00:56:48,440
គ្មានតន្ត្រី។

1235
00:57:27,840 --> 00:57:28,520
ច្របូកច្របល់ម្តងទៀត។

1236
00:57:28,520 --> 00:57:28,960
ទេ

1237
00:57:28,960 --> 00:57:29,560
ខ្ញុំនឹងរាំ។

1238
00:57:30,440 --> 00:57:31,280
ខ្ញុំនឹងរាំ។

1239
00:57:57,400 --> 00:57:58,160
ខ្ញុំមិនអាចទេ។

1240
00:58:09,480 --> 00:58:10,360
តន្ត្រីចប់ហើយ។

1241
00:58:11,800 --> 00:58:12,320
ប្រាកដ​ជា​មិនមែន​ខ្ញុំ​ទេ។

1242
00:58:12,640 --> 00:58:13,320
ប្រាកដ​ជា​មិនមែន​ខ្ញុំ​ទេ។

1243
00:58:13,840 --> 00:58:14,280
វាមិនមែនជាអ្នកទេ។

1244
00:58:14,280 --> 00:58:15,120
ខ្ញុំមិនគិតថាវាជារបស់នាងទេ។

1245
00:58:15,640 --> 00:58:16,680
នាងពិតជាអាជីព។

1246
00:58:17,160 --> 00:58:17,720
មិនមែន Teng ទេ។

1247
00:58:19,600 --> 00:58:20,280
បាទ។

1248
00:58:22,080 --> 00:58:22,440
មិនចាំបាច់ទេ។

1249
00:58:23,440 --> 00:58:24,440
អ្នកទើបតែបានសាកល្បង Chengcheng ។

1250
00:58:24,440 --> 00:58:25,320
តើគាត់មានភ្លេងទេ?

1251
00:58:25,320 --> 00:58:25,800
គ្មានតន្ត្រី។

1252
00:58:25,800 --> 00:58:26,360
អត់មានភ្លេងទេ?

1253
00:58:27,160 --> 00:58:27,560
ទេ

1254
00:58:28,080 --> 00:58:28,760
ខ្ញុំអាចនិយាយបានតែបទនេះ។

1255
00:58:28,760 --> 00:58:30,840
គឺចាស់បន្តិចសម្រាប់ខ្ញុំ។

1256
00:58:31,360 --> 00:58:32,120
តើវាមិនចាស់សម្រាប់អ្នកណា?

1257
00:58:32,120 --> 00:58:32,680
អ្នកប្រាប់ខ្ញុំ។

1258
00:58:33,120 --> 00:58:33,840
ជិតដល់សម័យតេង។

1259
00:58:34,640 --> 00:58:35,160
មិនពិតទេ។

1260
00:58:37,320 --> 00:58:39,080
ប៉ុន្តែ​ខ្ញុំ​គិត​ថា​ខ្ញុំ​នឹង​រើស​យក​ពីរ​ដែល​គួរ​ឱ្យ​សង្ស័យ។

1261
00:58:39,080 --> 00:58:39,600
ខ្ញុំគិតថា

1262
00:58:39,600 --> 00:58:41,120
ពីព្រោះយើងទាំងអស់គ្នាត្រូវបានប្រមូលផ្តុំនៅទីនេះ។

1263
00:58:41,680 --> 00:58:42,280
នៅពេលដែលយើងនៅជាមួយគ្នា,

1264
00:58:42,280 --> 00:58:43,240
អ្នកទាំងបីនៅទីនោះ។

1265
00:58:43,520 --> 00:58:44,040
យើងទាំងបី។

1266
00:58:44,440 --> 00:58:45,360
តោះកុំនិយាយអំពី Bing ។

1267
00:58:45,360 --> 00:58:46,280
Bing ប្រហែលជាបានមើលផងដែរ។

1268
00:58:46,280 --> 00:58:47,320
ប៉ុន្តែអ្នកទាំងពីរនៅទីនោះ។

1269
00:58:47,720 --> 00:58:48,480
ខ្ញុំមិនបានផ្លាស់ទីទាល់តែសោះ។

1270
00:58:48,840 --> 00:58:50,240
ហើយខ្ញុំបានបន្តមើលពីទីនោះ។

1271
00:58:50,240 --> 00:58:51,520
តើការរាំរបស់អ្នកត្រឹមត្រូវដែរឬទេ?

1272
00:58:51,520 --> 00:58:52,760
ចុះហេតុអ្វីបានជាអ្នកមិនមើលនៅទីនេះ?

1273
00:58:52,760 --> 00:58:53,560
អ្នកបានមើលពីទីនោះ។

1274
00:58:53,560 --> 00:58:55,040
ព្រោះខ្ញុំគិតពេលអ្នករាំ

1275
00:58:55,040 --> 00:58:56,280
ពិតជាមានអ្វីមួយបិទ។

1276
00:58:56,280 --> 00:58:57,760
ខ្ញុំជាមនុស្សដំបូងដែលនិយាយ។

1277
00:58:57,760 --> 00:58:58,760
គាត់សង្ស័យខ្ញុំមុន។

1278
00:58:58,760 --> 00:59:00,480
ខ្ញុំបានចែករំលែកព័ត៌មានទាំងអស់នេះជាមុនសិន។

1279
00:59:00,680 --> 00:59:01,840
នៅដើមដំបូង,

1280
00:59:01,840 --> 00:59:02,800
តើ Chengcheng យល់​ឃើញ​ទេ?

1281
00:59:03,280 --> 00:59:04,680
គាត់ទទួលបានក្បាច់រាំត្រឹមត្រូវ។

1282
00:59:05,040 --> 00:59:05,760
ខ្ញុំបានឃើញពួកគេរួចហើយ។

1283
00:59:05,760 --> 00:59:07,560
អ្នកផ្សេងទៀតបានបញ្ចប់នៅទីនេះ។

1284
00:59:07,560 --> 00:59:08,840
គាត់បានធ្វើវាម្តងទៀតជាមួយខ្ញុំ។

1285
00:59:10,280 --> 00:59:11,440
ខ្ញុំបានប្រាប់គាត់ឱ្យធ្វើថ្មី។

1286
00:59:11,960 --> 00:59:12,640
គាត់បាននិយាយថា

1287
00:59:14,120 --> 00:59:14,840
ខ្ញុំគ្រាន់តែបង្ហាញគាត់

1288
00:59:15,800 --> 00:59:16,560
ទស្សនិកជនជាទីគោរព!

1289
00:59:16,560 --> 00:59:18,280
ខ្ញុំ​បាន​បង្ហាញ​តែ​បី​ចំណុច​ប៉ុណ្ណោះ។

1290
00:59:18,600 --> 00:59:19,720
ខ្ញុំបង្ហាញគាត់តែពីរតួប៉ុណ្ណោះ។

1291
00:59:21,320 --> 00:59:22,880
នេះគឺជាតួអក្សរចិនដ៏ស្រស់ស្អាតពីរ។

1292
00:59:22,880 --> 00:59:23,640
តើអ្នកអាចយល់ពីពួកគេទេ?

1293
00:59:24,960 --> 00:59:25,720
ដឹងអត់?

1294
00:59:26,360 --> 00:59:27,360
តើអ្នកទាំងអស់គ្នាសរសេរអត់?

1295
00:59:31,800 --> 00:59:33,200
ប៉ុន្តែគាត់ប្រហែលជាទាយវានៅពេលនោះ។

1296
00:59:34,440 --> 00:59:35,160
ស្តេចចចក

1297
00:59:36,480 --> 00:59:37,160
បងប្រុស

1298
00:59:37,480 --> 00:59:38,960
បងប្រុសឆ្លាតរបស់ខ្ញុំ។

1299
00:59:41,400 --> 00:59:42,160
បោះឆ្នោតឱ្យគាត់។

1300
00:59:43,920 --> 00:59:44,800
បោះឆ្នោតឱ្យគាត់។

1301
00:59:45,560 --> 00:59:46,560
ប្រាកដ​ជា​មិនមែន​ខ្ញុំ​ទេ។

1302
00:59:46,560 --> 00:59:47,560
ពេលនេះខ្ញុំបានធ្វើវាហើយ។

1303
00:59:47,560 --> 00:59:48,560
ដើម្បីកុំឱ្យមនុស្សគ្រប់គ្នាសង្ស័យខ្ញុំ។

1304
00:59:48,560 --> 00:59:49,720
ដូច្នេះខ្ញុំបានធ្វើចលនាមួយ។

1305
00:59:49,720 --> 00:59:51,080
ថាគ្មាននរណាម្នាក់ធ្វើម្តងទៀតទេ។

1306
00:59:52,400 --> 00:59:52,880
ផ្លាស់ទីអ្វី?

1307
00:59:52,880 --> 00:59:53,320
ផ្លាស់ទីអ្វី?

1308
00:59:58,040 --> 00:59:58,640
ចង់មើល។

1309
00:59:59,240 --> 01:00:00,760
យីលូន អេប៊ីង

1310
01:00:01,920 --> 01:00:02,280
បងប្រុស

1311
01:00:02,280 --> 01:00:03,400
បងប្រុស បន្ទាប់ពីអ្នកមើលខ្ញុំរាំ

1312
01:00:03,400 --> 01:00:04,480
បន្ទាប់មកអ្នកធ្វើរឿងរបស់អ្នក។

1313
01:00:06,960 --> 01:00:07,920
ខ្ញុំទើបតែធ្វើចលនាមួយនេះ។

1314
01:00:08,600 --> 01:00:10,200
ដូច្នេះ​ខ្ញុំ​បាន​ចំណាយ​ពេល​ដែល​នៅ​សល់​ក្នុង​ការ​សង្កេត។

1315
01:00:10,200 --> 01:00:11,720
ខ្ញុំពិតជាចង់ដកខ្លួនចេញ

1316
01:00:11,720 --> 01:00:13,200
ជាស្តេចចចកដែលអាចធ្វើទៅបាន។

1317
01:00:13,200 --> 01:00:14,720
គ្រាន់​តែ​ចង់​បញ្ជាក់​មែន​ទេ?

1318
01:00:14,720 --> 01:00:15,440
តើតួនាទីរបស់ខ្ញុំជាអ្វី?

1319
01:00:17,600 --> 01:00:19,760
Jingyu មានអ្វីថ្មី?

1320
01:00:20,840 --> 01:00:21,960
តើអ្នកត្រូវការឱ្យខ្ញុំពណ៌នាទេ?

1321
01:00:22,280 --> 01:00:24,600
ផ្តល់ឱ្យយើងនូវអ្វីដែលស្រស់ជាងនេះបន្តិច។

1322
01:00:24,600 --> 01:00:27,280
អ្វីមួយដែលយើងអាចយល់បានយ៉ាងងាយស្រួល។

1323
01:00:27,280 --> 01:00:27,720
ក្តៅ។

1324
01:00:30,080 --> 01:00:30,520
ក្តៅ។

1325
01:00:31,080 --> 01:00:31,480
តើ Jingyu និយាយអ្វីខ្លះ?

1326
01:00:31,480 --> 01:00:31,880
ក្តៅ។

1327
01:00:32,320 --> 01:00:32,800
បាទ។

1328
01:00:32,800 --> 01:00:33,080
បោះឆ្នោតឱ្យគាត់។

1329
01:00:34,320 --> 01:00:34,720
អ្វី?

1330
01:00:37,000 --> 01:00:37,320
អ្វី?

1331
01:00:38,160 --> 01:00:39,560
ខ្ញុំនៅតែគិតថា Chengcheng បន្តិច ...

1332
01:00:39,840 --> 01:00:41,080
គាត់មានភាពរញ៉េរញ៉ៃបន្តិចនៅពេលចាប់ផ្តើម។

1333
01:00:43,160 --> 01:00:44,600
ខ្ញុំជាមនុស្សដំបូងដែលនិយាយ។

1334
01:00:45,320 --> 01:00:46,800
វាគ្មិន​ដំបូង​តែង​តែ​ជជែក​តវ៉ា។

1335
01:00:49,320 --> 01:00:50,840
ខ្ញុំគិតថាអ្នកអាចយល់បាន។

1336
01:00:51,600 --> 01:00:52,080
ពីរ​នាក់​នេះ​មាន​ការ​សង្ស័យ។

1337
01:00:52,800 --> 01:00:52,840
បាទ។

1338
01:00:52,840 --> 01:00:53,440
គឺគាត់។

1339
01:00:53,760 --> 01:00:54,760
ពេល​អ្នក​ដទៃ​ដាក់​គោលដៅ​លើ​នរណា​ម្នាក់

1340
01:00:54,760 --> 01:00:55,480
គាត់គ្រាន់តែធ្វើតាម។

1341
01:00:55,480 --> 01:00:56,280
ទេ ខ្ញុំសូមប្រាប់អ្នក -

1342
01:00:56,280 --> 01:00:57,800
មើលពីរបៀបដែលខ្ញុំលេងពីរជុំនេះ។

1343
01:00:57,800 --> 01:00:59,520
ខ្ញុំជាចៀមតូចនៅក្នុងជុំទីមួយ។

1344
01:00:59,520 --> 01:01:01,080
ស្ថានភាពរបស់ខ្ញុំគឺដូចគ្នានឹងជុំនេះ។

1345
01:01:01,320 --> 01:01:01,760
ទេ

1346
01:01:01,760 --> 01:01:02,560
ព្រោះជុំនេះ

1347
01:01:02,880 --> 01:01:03,880
ការគិតរបស់ខ្ញុំបានផ្លាស់ប្តូរម្តងទៀត។

1348
01:01:03,880 --> 01:01:04,920
ជុំនេះខ្ញុំជាកូនឆ្កែចចក។

1349
01:01:06,680 --> 01:01:07,480
ទាំងពីរ​នាក់​នេះ​បោះឆ្នោត​រួមគ្នា​។

1350
01:01:07,480 --> 01:01:08,440
ពួក​គេ​បាន​សហការ​គ្នា​រួច​ហើយ។

1351
01:01:10,760 --> 01:01:11,280
ដាស៊ី មកទីនេះ។

1352
01:01:13,880 --> 01:01:14,880
អ្នកមិនមានខួរក្បាលទេ។

1353
01:01:15,200 --> 01:01:17,440
គ្មាននរណាម្នាក់ដឹងពីតួនាទីរបស់គ្នាទៅវិញទៅមកទេ។

1354
01:01:18,680 --> 01:01:19,240
ត្រលប់មកវិញយ៉ាងឆាប់រហ័ស។

1355
01:01:23,200 --> 01:01:24,200
ពីរ​នាក់​នេះ​ច្បាស់​ជា​សង្ស័យ។

1356
01:01:26,240 --> 01:01:27,160
Xiaobai អ្នកពិតជាទុកចិត្តខ្ញុំមែនទេ?

1357
01:01:29,320 --> 01:01:31,160
ខ្ញុំត្រូវការខួរក្បាលឆ្លាតដូចអ្នកដែរ។

1358
01:01:32,320 --> 01:01:34,200
ជួយចចកឈ្នះជុំនេះ។

1359
01:01:34,200 --> 01:01:34,960
ប្រសិនបើគាត់ជាចៀមតូច

1360
01:01:34,960 --> 01:01:36,120
គាត់នឹងមិននិយាយច្រើនទេ។

1361
01:01:40,520 --> 01:01:41,280
ត្រៀមខ្លួនដើម្បីបោះឆ្នោត។

1362
01:01:41,880 --> 01:01:44,080
បី ពីរ មួយ - សូមបោះឆ្នោត។

1363
01:01:46,520 --> 01:01:47,280
បីសន្លឹកឆ្នោតសម្រាប់មួយ។

1364
01:01:50,600 --> 01:01:51,600
Xiaobai មានការសង្ស័យ។

1365
01:01:52,520 --> 01:01:53,600
ខ្ញុំទើបតែដឹង។

1366
01:01:53,920 --> 01:01:55,320
នរណាម្នាក់ដែលឆ្លាតនេះ -

1367
01:01:58,360 --> 01:01:59,520
យើងនឹងបង្ហាញតួនាទីក្នុងពេលឆាប់ៗនេះ។

1368
01:01:59,520 --> 01:02:00,080
អ្វីដែលអ្នកបាននិយាយ -

1369
01:02:00,680 --> 01:02:01,480
អំពីតួនាទីរបស់ខ្ញុំ -

1370
01:02:01,760 --> 01:02:03,000
តួនាទីរបស់ Chengcheng គឺ

1371
01:02:08,160 --> 01:02:08,520
ចៀមតូច។

1372
01:02:18,280 --> 01:02:19,000
ឥឡូវនេះអ្នកដឹងហើយ។

1373
01:02:20,080 --> 01:02:21,120
វាគ្មិនដំបូង -

1374
01:02:21,120 --> 01:02:22,760
បានផ្តល់ឱ្យអ្នកនូវតម្រុយទាំងអស់។

1375
01:02:22,760 --> 01:02:23,720
ហើយបន្ទាប់មកគាត់បានកំណត់គោលដៅខ្ញុំ។

1376
01:02:23,720 --> 01:02:25,120
ហើយ​អ្នក​ខ្លះ​បាន​តាម​ដាន​ការ​បោះ​ឆ្នោត​របស់​គាត់។

1377
01:02:25,120 --> 01:02:26,080
ប៉ុន្តែខ្ញុំពិតជាបុរសល្អម្នាក់។

1378
01:02:28,080 --> 01:02:29,280
ឥឡូវនេះនៅក្នុងក្រុមទាំងមូល,

